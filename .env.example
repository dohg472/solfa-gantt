PORT=5177

# 직접 만든 Notion integration secret입니다.
NOTION_TOKEN=
NOTION_VERSION=2022-06-28

# 읽기 전용 원본: 채널팀 플랜
NOTION_READ_DATABASE_ID=20175c38-e3be-4b38-b81e-e8394914431e

# 쓰기 대상: 개인 페이지 간트_확인 > 프로젝트 DB
NOTION_WRITE_DATABASE_ID=b6e89562-3634-4ef2-bd75-c592a438e372

# 선택: 간트_확인 페이지 ID. 비워두면 쓰기 DB의 부모 페이지를 자동으로 찾습니다.
NOTION_EMBED_PAGE_ID=

# 채널팀 플랜 속성 매핑
NOTION_TITLE_PROP=이름
NOTION_DATE_PROP=날짜
NOTION_START_PROP=날짜
NOTION_END_PROP=
NOTION_CHANNEL_PROP=채널명
NOTION_PROJECT_PROP=이름
NOTION_DETAIL_PROP=카테고리
NOTION_CATEGORY_PROP=카테고리
NOTION_STATUS_PROP=상태
NOTION_ASSIGNEE_PROP=사람

# 간트_확인 > 프로젝트 DB 속성 매핑
NOTION_WRITE_TITLE_PROP=프로젝트
NOTION_WRITE_CHANNEL_PROP=채널
NOTION_WRITE_PROJECT_PROP=프로젝트
NOTION_WRITE_DETAIL_PROP=일정
NOTION_WRITE_DATE_PROP=날짜
NOTION_WRITE_STATUS_PROP=상태
NOTION_WRITE_ASSIGNEE_PROP=담당자
NOTION_WRITE_DESCRIPTION_PROP=메모

# 기본값 false: 간트에서 삭제해도 대상 DB 페이지를 보관 처리하지 않습니다.
APP_ALLOW_TARGET_ARCHIVE=false

# 공개 HTTPS 임베드 주소를 만들 때 API를 보호하는 키입니다.
# 노션에는 /embed?key=여기값 형태로 넣습니다.
APP_EMBED_KEY=

# 고정 도메인을 만들기 전 임시 공개 주소를 서버 시작 때 자동으로 만들고,
# 등록된 노션 임베드 블록을 새 임시 주소로 갱신합니다.
# 운영용으로는 APP_PUBLIC_BASE_URL 또는 CLOUDFLARE_TUNNEL_HOSTNAME을 쓰는 것이 더 안정적입니다.
APP_AUTO_TEMP_TUNNEL=false

# 노션에 고정으로 넣을 공개 HTTPS 주소입니다.
# 직접 배포 주소를 쓸 때만 채웁니다. 비워두면 CLOUDFLARE_TUNNEL_HOSTNAME으로 자동 계산합니다.
# 예: https://gantt.example.com
APP_PUBLIC_BASE_URL=

# Cloudflare named tunnel 운영용 설정입니다.
# CLOUDFLARE_TUNNEL_HOSTNAME은 Cloudflare에 연결된 도메인의 서브도메인이어야 합니다.
# 이 값만 채워도 앱은 https://hostname/embed/APP_EMBED_KEY 형식의 고정 주소를 인식합니다.
CLOUDFLARE_TUNNEL_NAME=solpa-gantt
CLOUDFLARE_TUNNEL_HOSTNAME=
